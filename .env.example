# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici

# ---------------------------------------------------------------------------
# Trackers (une seule clé app pour tout le foyer)
# ---------------------------------------------------------------------------

# AniList — https://anilist.co/settings/developer
# Type : Authorization Code (+ Client Secret)
# Redirect URI à enregistrer (exactement) :
#   - Dev web : http://localhost:1420/tracker-oauth.html
#   - App Tauri / mobile : mangatheque://tracker-callback
VITE_ANILIST_CLIENT_ID=
VITE_ANILIST_CLIENT_SECRET=

# MyAnimeList — https://myanimelist.net/apiconfig
# Type : OAuth (PKCE plain, pas de secret client côté app)
# Redirect URI à enregistrer (exactement) :
#   - Dev web : http://localhost:1420/tracker-oauth.html
#   - App Tauri / mobile : mangatheque://tracker-callback
VITE_MAL_CLIENT_ID=

# Ne jamais committer .env ni la clé service_role Supabase.
#
# GitHub Actions (Settings > Secrets) — mêmes valeurs :
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#   VITE_ANILIST_CLIENT_ID
#   VITE_ANILIST_CLIENT_SECRET
#   VITE_MAL_CLIENT_ID
