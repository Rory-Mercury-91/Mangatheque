# Supabase — https://supabase.com/dashboard/project/sieiurhzszdasnvxpuik/settings/api
VITE_SUPABASE_URL=https://sieiurhzszdasnvxpuik.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Trackers (une seule clé app pour tout le foyer)
# AniList : https://anilist.co/settings/developer — Implicit Grant
#   Redirect URI web : http://localhost:1420/tracker-oauth.html (dev)
#   Redirect URI Tauri : mangatheque://tracker-callback
VITE_ANILIST_CLIENT_ID=

# MyAnimeList : https://myanimelist.net/apiconfig — OAuth PKCE (plain)
#   Redirect URI web : http://localhost:1420/tracker-oauth.html (dev)
#   Redirect URI Tauri : mangatheque://tracker-callback
VITE_MAL_CLIENT_ID=

# Ne jamais committer la clé service_role dans le client.
#
# CI GitHub Actions : creer aussi ces secrets (Settings > Secrets > Actions)
# a partir des memes valeurs que votre .env local :
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#   VITE_ANILIST_CLIENT_ID
#   VITE_MAL_CLIENT_ID
